#!/usr/bin/env bash
set -euo pipefail

# Manual websearch/follow-up debug harness.
# Usage:
#   ./test1
#   ./test1 "what was price of oil november 2022" "whats the price of bitcoin in november 2022" "what is its price now"

PYTHON_BIN="${PYTHON_BIN:-python}"

$PYTHON_BIN - "$@" <<'PY'
import asyncio
import json
import logging
import sys

try:
    from handlers.routing import decide_route
    from handlers.websearch import WebSearchHandler
    from handlers.tool_context import ToolContextStore
    from handlers.followup_resolver import FollowUpResolver
except Exception as e:
    print("[test1] Import/bootstrap failure:", repr(e))
    print("[test1] Ensure dependencies are installed (e.g., `pip install -r requirements.txt`) and run again.")
    raise SystemExit(2)

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s [%(name)s] %(message)s",
)

queries = sys.argv[1:] if len(sys.argv) > 1 else [
    "what was the price of oil november 2022",
    "whats the price of bitcoin in november 2022",
    "what is its price now",
]

state = {
    "last_tool_type": "",
    "has_tool_context": False,
    "last_finance_intent": "",
}

store = ToolContextStore(ttl_seconds=600)
resolver = FollowUpResolver()
ws = WebSearchHandler()
session_id = "manual-debug"

print("\n=== WEBSEARCH DEBUG RUN ===")
print("Queries:")
for i, q in enumerate(queries, 1):
    print(f"  {i}. {q}")
print()

async def run():
    global state
    for i, q in enumerate(queries, 1):
        print(f"\n--- TURN {i} ---")
        print(f"USER: {q}")

        decision = decide_route(q, agent_state=state)
        print("ROUTE DECISION:")
        print(json.dumps({
            "route": decision.route,
            "reason": decision.reason,
            "signals": decision.signals,
        }, indent=2))

        rewritten = q
        if state.get("has_tool_context"):
            ctx = store.get(session_id)
            r = resolver.resolve(q, ctx)
            if r and r.action == "rewrite_query" and r.rewritten_query:
                rewritten = r.rewritten_query
                print("FOLLOWUP REWRITE:")
                print(json.dumps({
                    "action": r.action,
                    "rewritten_query": r.rewritten_query,
                    "previous_query": r.previous_query,
                    "context_note": r.context_note,
                }, indent=2))

        if decision.route == "websearch":
            results = await ws.search(
                rewritten,
                tool_veto=decision.tool_veto,
                reason=decision.reason,
                signals=decision.signals,
            )
            print(f"RESULT COUNT: {len(results)}")
            for idx, item in enumerate(results[:3], 1):
                print(f"  [{idx}] title={item.get('title')}")
                print(f"      url={item.get('url')}")
                print(f"      category={item.get('category')} source={item.get('source')}")
                desc = (item.get('description') or '').replace('\n', ' ').strip()
                print(f"      description={desc[:240]}")

            if results:
                # persist context for follow-up resolution
                store.set(session_id, "finance", rewritten, results)
                inferred = (decision.signals or {}).get("intent", "")
                state = {
                    "last_tool_type": "finance" if inferred in {"stock/commodity", "crypto", "forex"} else inferred or "websearch",
                    "has_tool_context": True,
                    "last_finance_intent": inferred if inferred in {"stock/commodity", "crypto", "forex"} else state.get("last_finance_intent", ""),
                }
        else:
            print("SKIP: non-websearch route")

    print("\n=== END DEBUG RUN ===")

asyncio.run(run())
PY
